{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "sh '${CLAUDE_PLUGIN_ROOT}/scripts/merge-guard.sh'"
          }
        ]
      },
      {
        "matcher": "PowerShell",
        "hooks": [
          {
            "type": "command",
            "command": "powershell -NoProfile -ExecutionPolicy Bypass -File '${CLAUDE_PLUGIN_ROOT}/scripts/merge-guard.ps1'"
          }
        ]
      }
    ]
  }
}
